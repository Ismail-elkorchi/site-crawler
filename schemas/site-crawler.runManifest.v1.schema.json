        "string",
        "null"
      ]
    },
    "stopReason": {
      "type": [
        "string",
        "null"
      ]
    },
    "outputDirectory": {
      "type": [
        "string",
        "null"
      ]
    },
    "resumedFrom": {
      "type": [
        "string",
        "null"
      ]
