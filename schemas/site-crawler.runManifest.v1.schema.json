    "operationalConfigFingerprint": {
      "type": "string"
    },
    "startedAt": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "schemaSetVersion": {
      "type": "number"
    },
    "rawSnapshotsEnabled": {
