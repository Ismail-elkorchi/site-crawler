    "sensitive",
    "stats",
    "runtime",
    "deliveryGuarantees",
    "seeds",
    "htmlParserVersion",
    "xmlParserVersion",
    "finishedAt",
    "stopReason",
    "outputDirectory",
    "resumedFrom",
    "stopDetail",
    "fatalError"
