    "schemaVersion",
    "runId",
    "uniqueKey",
    "rawUrl",
    "source",
    "seedUrl",
    "createdAt",
    "depth",
    "firstSeen",
    "decision",
    "requestId",
    "resolvedUrl",
    "normalizedUrl",
    "referrerUrl",
    "seedLabel"
